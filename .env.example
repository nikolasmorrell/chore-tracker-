# ============================================================
# Serva — example environment variables
# Copy this file to .env and fill in real values for local dev.
# Never commit a real .env — it is listed in .gitignore.
# ============================================================

# ---------- App ----------
APP_ENV=development
APP_NAME=serva
APP_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
LOG_LEVEL=INFO
# JSON-encoded list of origins the API accepts credentialed requests from.
CORS_ALLOW_ORIGINS=["http://localhost:3000"]

# ---------- Database ----------
# Production providers (Render, Heroku, Supabase) hand out plain `postgres://`
# URLs; the app auto-normalizes them to the right async/sync dialects.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/serva
DATABASE_SYNC_URL=postgresql+psycopg://postgres:postgres@localhost:5432/serva

# ---------- Redis ----------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---------- Auth ----------
# Generate a production secret: `python -c "import secrets; print(secrets.token_urlsafe(64))"`
JWT_SECRET=dev-insecure-change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000
PASSWORD_RESET_TTL_SECONDS=3600
INVITE_TTL_SECONDS=604800

# ---------- Object Storage (S3 or MinIO) ----------
S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123
S3_BUCKET_DOCUMENTS=serva-documents
S3_BUCKET_CALL_AUDIO=serva-call-audio
S3_PRESIGNED_URL_TTL_SECONDS=900

# ---------- Claude / Anthropic ----------
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_PRIMARY=claude-opus-4-7
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MAX_OUTPUT_TOKENS=4096

# ---------- OCR (AWS Textract or fallback) ----------
OCR_PROVIDER=textract
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ---------- Voice (Twilio) ----------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VOICE_WEBHOOK_SECRET=
DEEPGRAM_API_KEY=
TTS_PROVIDER=deepgram
TTS_VOICE=aura-asteria-en

# ---------- Email ----------
SENDGRID_API_KEY=
EMAIL_FROM_ADDRESS=no-reply@serva.app
EMAIL_FROM_NAME=Serva

# ---------- Billing (Stripe) ----------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_TRIAL_DAYS=14

# ---------- Rate limiting ----------
RATE_LIMIT_PER_IP_PER_MINUTE=120
RATE_LIMIT_PER_TENANT_PER_MINUTE=600

# ---------- Observability ----------
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ---------- Frontend (Next.js) ----------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
